# [MANDATORY] Google Gemini API Key
# This is required for the AI vision and decision-making features.
# You can get a free key here: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyYourKeyHere12345

# [OPTIONAL] Debug Mode
# Set to 'true' to see more detailed logs in the console during training/testing
DEBUG=false

# [OPTIONAL] Model Configuration
# If you want to force a specific model path (default is usually auto-detected)
# MODEL_PATH=./models/best_model.h5