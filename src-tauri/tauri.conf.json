{
  "build": {
    "beforeDevCommand": "npm --prefix tauri-ui run dev",
    "beforeBuildCommand": "npm --prefix tauri-ui run build",
    "devPath": "http://localhost:5173",
    "distDir": "../tauri-ui/dist",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "BOT-MMORPG-AI",
    "version": "0.1.7"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "execute": true,
        "open": true,  
        "sidecar": false
      },
      "fs": {
        "all": true,
        "scope": [
          "$APP/*",
          ".env",
          "catalog/**",
          "trained_models/**",
          "datasets/**",
          "modelhub_registry.json",
          "active_model.json",
          "modelhub_settings.json"
        ]
      },
      "path": { "all": true },
      "window": { "all": true }
    },
    "bundle": {
      "active": true,
      "category": "Game",
      "targets": ["nsis"],
      "identifier": "com.bot.mmorpg.ai",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "resources": [
        "resources/**",
        "drivers/**",
        "../versions/**",
        "../.env",
        "../catalog/**",
        "../modelhub_registry.json",
        "../active_model.json",
        "../modelhub_settings.json",
        "../scripts/modelhub_cli.py",
        "../modelhub/**"
      ],
      "windows": {
        "nsis": {
          "installMode": "perMachine",
          "license": "./license.txt"
        }
      }
    },
    "windows": [
      {
        "title": "BOT-MMORPG-AI Launcher",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://generativelanguage.googleapis.com https://api.openai.com",
      "freezePrototype": true
    }
  }
}