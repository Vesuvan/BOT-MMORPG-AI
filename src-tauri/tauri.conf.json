{
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "../tauri-ui",
    "distDir": "../tauri-ui",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "BOT-MMORPG-AI",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "execute": true,
        "open": true,
        "sidecar": false
      },
      "fs": {
        "all": false,
        "readFile": true,
        "writeFile": true,
        "readDir": true,
        "createDir": true,
        "exists": true,
        "scope": [
          "$APP/**",
          "$APPDATA/**",
          "$CONFIG/**",
          "$LOCALDATA/**"
        ]
      }
    },
    "bundle": {
      "active": true,
      "category": "Game",
      "targets": [
        "nsis"
      ],
      "identifier": "com.bot.mmorpg.ai",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "resources": [
        "resources/**",
        "drivers/**"
      ],
      "windows": {
        "nsis": {
          "installMode": "perMachine",
          "license": "./license.txt",
          "template": "../installer/nsis_template.nsi"
        }
      }
    },
    "windows": [
      {
        "title": "BOT-MMORPG-AI Launcher",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://generativelanguage.googleapis.com https://api.openai.com",
      "freezePrototype": true
    }
  }
}