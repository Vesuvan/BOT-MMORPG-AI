{
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devPath": "../tauri-ui",
    "distDir": "../tauri-ui"
  },
  "package": {
    "productName": "BOT-MMORPG-AI",
    "version": "0.1.5"
  },
  "tauri": {
    "allowlist": {
      "shell": {
        "all": true
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "externalBin": [
        "binaries/main-backend"
      ],
      "identifier": "com.botmmorpg.ai",
      "icon": [
        "icons/icon.ico"
      ],
      "windows": {
        "nsis": {
          "installMode": "perMachine"
        }
      },
      "resources": [
        "resources/**",
        "drivers/**"
      ]
    },
    "windows": [
      {
        "title": "BOT MMORPG AI",
        "width": 1100,
        "height": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob:; connect-src 'self' http://127.0.0.1:* http://localhost:*; media-src 'self' data: blob:;"
    }
  }
}
