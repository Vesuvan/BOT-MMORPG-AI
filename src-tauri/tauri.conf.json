{
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devPath": "../tauri-ui",
    "distDir": "../tauri-ui"
  },
  "package": {
    "productName": "BOT-MMORPG-AI",
    "version": "0.1.5"
  },
  "tauri": {
    "allowlist": {
      "shell": {
        "all": true
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "externalBin": [
        "binaries/main-backend"
      ],
      "identifier": "com.botmmorpg.ai",
      "icon": [
        "icons/icon.ico"
      ],
      "windows": {
        "nsis": {
          "installMode": "perMachine",
          "template": "../installer/nsis_template.nsi"
        }
      }
    },
    "windows": [
      {
        "title": "BOT MMORPG AI",
        "width": 1100,
        "height": 700,
        "resizable": true
      }
    ]
  }
}
